{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:web",
  "outputDirectory": "web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/run-a", "schedule": "0 6 * * *" },
    { "path": "/api/run-b", "schedule": "30 6 * * *" }
  ],
  "functions": {
    "api/run-a.ts": { "maxDuration": 300, "memory": 3009 },
    "api/run-b.ts": { "maxDuration": 300, "memory": 3009 },
    "api/local-asset.ts": { "maxDuration": 30 },
    "api/generate-meme.ts": { "maxDuration": 300, "memory": 3009 }
  }
}